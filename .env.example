# Copy this file to .env.local in apps/web and apps/mobile
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SITE_GATE_PASSWORD=your-testing-password

# Used to build invitation links (apps/web only) — set to the real deployed
# URL in production, or invite links default to localhost.
NEXT_PUBLIC_APP_URL=https://www.erfar.se

# Invitation emails (apps/web only). Without RESEND_API_KEY, invites still
# work — the invite link is just shown in the UI instead of emailed.
RESEND_API_KEY=your-resend-api-key
# Requires a verified sending domain in Resend to send to arbitrary
# recipients; defaults to Resend's shared test address otherwise.
RESEND_FROM_EMAIL=Erfar <noreply@erfar.se>

# Company lookup during kommun signup (apps/web only, apiverket.se, free
# tier: 200 calls/day). Without it, users type company name/org number in
# manually — search is a convenience, not a hard requirement.
COMPANY_LOOKUP_API_KEY=your-apiverket-api-key
